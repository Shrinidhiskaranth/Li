<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Issue Book</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="form-box">
        <form action="/borrowed-books/add" method="POST">
            <h1 style="text-align: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Issue New Book</h1>
            <select name="usn" required>
                <option value="">Select Student</option>
                <% students.forEach(student=>{ %>
                    <option value="<%= student.usn %>">
                        <%= student.usn %> - <%= student.name %>
                    </option>
                <% }) %>
            </select>
            <select name="book_id" required>
                <option value="">Select Book</option>
                <% books.forEach(book=>{ %>
                    <option value="<%= book.id %>">
                        <%= book.title %>
                    </option>
                <% }) %>
            </select>
            <input type="date" name="borrow_date" required>
            <input type="date" name="return_date" required>
            <button type="submit">Issue Book</button>
        </form>
    </div>
</body>
</html>