<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Borrowed Books</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="main-page">
        <h1>Borrowed Books</h1>
        <a href="/borrowed-books/add" style="margin-right: 15px;">Issue New Book</a>
        <form action="/borrowed-books" method="GET" class="search-form" style="display: inline-block; margin-bottom: 20px;">
            <input type="text" name="search" placeholder="Search by USN, Student or Book" value="<%= search || '' %>" style="width: 300px; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px;">
            <button type="submit" style="padding: 12px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">Search</button>
        </form>
        <table>
            <tr>
                <th>Borrow Id</th>
                <th>USN</th>
                <th>Student Name</th>
                <th>Book Title</th>
                <th>Borrow Date</th>
                <th>Return Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
            <% borrowedBooks.forEach(book => { %>
                <tr>
                    <td><%= book.id %></td>
                    <td><%= book.usn %></td>
                    <td><%= book.name %></td>
                    <td><%= book.title %></td>
                    <td><%= book.borrow_date %></td>
                    <td><%= book.return_date %></td>
                    <td><%= book.status %></td>
                    <td>
                        <% if(book.status === 'Borrowed'){ %>
                            <a href="/borrowed-books/return/<%= book.id %>" class="edit">Return</a>
                        <% } else { %> 
                            <span style="color: #4CAF50; font-weight: bold;">Returned</span>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</body>
</html>