<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Books Management</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="main-page">
        <h1>Books Management</h1>
        <a href="/books/add" style="margin-right: 15px;">+ Add New Book</a>
        <form action="/books" method="GET" class="search-form" style="display: inline-block; margin-bottom: 20px;">
            <input type="text" name="search" placeholder="Search by title or author" value="<%= search || '' %>" style="width: 300px; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px;">
            <button type="submit" style="padding: 12px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">Search</button>
        </form>
        <table>
            <tr>
                <th>Book Id</th>
                <th>Title</th>
                <th>Author</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>
            <% books.forEach(book => { %>
                <tr>
                    <td><%= book.id %></td>
                    <td><%= book.title %></td>
                    <td><%= book.author %></td>
                    <td><%= book.quantity %></td>
                    <td>
                        <a href="/books/edit/<%= book.id %>" class="edit">Edit</a>
                        <a href="/books/delete/<%= book.id %>" class="delete" onclick="return confirm('Are you sure?')">Delete</a>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</body>
</html>