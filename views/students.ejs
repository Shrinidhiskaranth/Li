<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students Management</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed-books">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/library-visits">Library Visits</a>
        <a href="/logout">Logout</a>
    </div>
    <div class="main-page">
        <h1>Students Management</h1>
        <a href="/students/add" style="margin-right: 15px;">+ Register New Student</a>
        <form action="/students" method="GET" class="search-form" style="display: inline-block; margin-bottom: 20px;">
            <input type="text" name="search" placeholder="Search by USN or Name" value="<%= search || '' %>" style="width: 300px; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 14px;">
            <button type="submit" style="padding: 12px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">Search</button>
        </form>
        <table>
            <tr>
                <th>USN</th>
                <th>Name</th>
                <th>Branch</th>
                <th>Actions</th>
            </tr>
            <% students.forEach(student => { %>
                <tr>
                    <td><%= student.usn %></td>
                    <td><%= student.name %></td>
                    <td><%= student.branch %></td>
                    <td>
                        <a href="/students/edit/<%= student.usn %>" class="edit">Edit</a>
                        <a href="/students/delete/<%= student.usn %>" class="delete" onclick="return confirm('Are you sure?')">Delete</a>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</body>
</html>